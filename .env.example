# UniFi controller URL (e.g. https://192.168.1.1)
UNIFI_HOST=

# API key from UniFi Console (Settings → Control Plane → Integrations)
UNIFI_API_KEY=

# UniFi site name (default: "default")
# UNIFI_SITE=default

# Optional TTL (Time To Live) in seconds for the DNS records.
# If omitted, it will use UniFi's default value.
# DNS_TTL=300

# IP address of your lancache server
LANCACHE_IP=

# Comma-separated list of cache-domain names to include.
# If set, only these domain groups are synced. See full list at:
# https://github.com/uklans/cache-domains/blob/master/cache_domains.json
# Example: steam,epicgames,blizzard,riot,battlenet
# SERVICE_ALLOWLIST=

# Comma-separated list of cache-domain names to exclude.
# Ignored if SERVICE_ALLOWLIST is set.
# SERVICE_BLOCKLIST=

# Set to "true" to log what would be done without making changes
# DRY_RUN=false

# Cron expression for scheduled syncs (standard 5-field cron).
# If not set, a random daily time is generated on startup.
# Examples:
#   "0 3 * * *"   = every day at 03:00
#   "*/30 * * * *" = every 30 minutes
# CRON_SCHEDULE=
